# Stripe Configuration
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key_here
# From `stripe listen --forward-to localhost:3000/api/webhooks/stripe` locally,
# or the signing secret shown when creating the endpoint in the Stripe Dashboard for production
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_signing_secret_here

# Resend Email Service Configuration
RESEND_API_KEY=re_your_resend_api_key_here
RESEND_ADMIN_EMAIL=admin@rotem-architecture.co.il

RESEND_FROM_EMAIL="onboarding@resend.dev"

# Old AWS SES Configuration (deprecated - remove after migration)
# AWS_ACCESS_KEY_ID=your_aws_access_key
# AWS_SECRET_ACCESS_KEY=your_aws_secret_key
# AWS_REGION=us-east-1
# SES_FROM_EMAIL=noreply@yourcompany.com

# reCAPTCHA Configuration
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=your_recaptcha_site_key_here
RECAPTCHA_SECRET_KEY=your_recaptcha_secret_key_here

# Database Configuration
# DATABASE_URL = "Transaction" pooler connection (port 6543)
# DIRECT_URL   = "Session"/direct connection (port 5432), required by prisma/schema.prisma
DATABASE_URL=your_database_url_here
DIRECT_URL=your_direct_database_url_here

# NextAuth Configuration
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your_nextauth_secret_here

# Application URLs
NEXT_PUBLIC_BASE_URL=http://localhost:3000
